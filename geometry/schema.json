{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/olemmela/terassi/geometry/schema.json",
  "title": "Rakennelman geometria",
  "type": "object",
  "required": ["project", "profiles", "members", "connections", "surfaces"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "project": { "$ref": "#/$defs/project" },
    "reference_surfaces": {
      "type": "array",
      "items": { "$ref": "#/$defs/reference_surface" }
    },
    "points": {
      "type": "array",
      "items": { "$ref": "#/$defs/named_point" }
    },
    "profiles": {
      "type": "array",
      "items": { "$ref": "#/$defs/profile" }
    },
    "members": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "columns": { "type": "array", "items": { "$ref": "#/$defs/column" } },
        "beams":   { "type": "array", "items": { "$ref": "#/$defs/beam" } },
        "rafters": { "type": "array", "items": { "$ref": "#/$defs/beam" } },
        "purlins": { "type": "array", "items": { "$ref": "#/$defs/beam" } }
      }
    },
    "connections": { "type": "array", "items": { "$ref": "#/$defs/connection" } },
    "surfaces":    { "type": "array", "items": { "$ref": "#/$defs/surface" } },
    "foundations": { "type": "array", "items": { "$ref": "#/$defs/foundation" } }
  },

  "$defs": {
    "project": {
      "type": "object",
      "required": ["id", "name", "units", "coordinate_system"],
      "additionalProperties": false,
      "properties": {
        "id":        { "type": "string" },
        "name":      { "type": "string" },
        "site":      { "type": "string" },
        "standards": { "type": "array", "items": { "type": "string" } },
        "units": {
          "type": "object",
          "required": ["length", "angle", "mass"],
          "additionalProperties": false,
          "properties": {
            "length": { "const": "mm" },
            "angle":  { "const": "deg" },
            "mass":   { "const": "kg" }
          }
        },
        "coordinate_system": {
          "type": "object",
          "required": ["origin_description", "x_axis", "y_axis", "z_axis"],
          "additionalProperties": false,
          "properties": {
            "origin_description": { "type": "string" },
            "x_axis":             { "type": "string" },
            "y_axis":             { "type": "string" },
            "z_axis":             { "type": "string" }
          }
        }
      }
    },

    "point": {
      "type": "object",
      "required": ["x", "y", "z"],
      "additionalProperties": false,
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "z": { "type": "number" }
      }
    },

    "named_point": {
      "oneOf": [
        {
          "type": "object",
          "required": ["id", "x", "y", "z"],
          "additionalProperties": false,
          "properties": {
            "id": { "type": "string" },
            "x":  { "type": "number" },
            "y":  { "type": "number" },
            "z":  { "type": "number" }
          }
        },
        {
          "type": "object",
          "required": ["id", "ref"],
          "additionalProperties": false,
          "properties": {
            "id":  { "type": "string" },
            "ref": { "type": "string" },
            "dx":  { "type": "number", "default": 0 },
            "dy":  { "type": "number", "default": 0 },
            "dz":  { "type": "number", "default": 0 }
          }
        }
      ]
    },

    "profile": {
      "type": "object",
      "required": ["id", "name"],
      "additionalProperties": false,
      "properties": {
        "id":       { "type": "string" },
        "name":     { "type": "string" },
        "material": { "type": "string" },
        "b_mm":     { "type": "number" },
        "h_mm":     { "type": "number" },
        "count":    { "type": "integer", "minimum": 1 }
      }
    },

    "reference_surface": {
      "type": "object",
      "required": ["id", "type", "placement", "local_shape"],
      "additionalProperties": false,
      "properties": {
        "id":          { "type": "string" },
        "type":        { "type": "string", "enum": ["building_wall", "building_roof", "floor", "ground"] },
        "ref":         { "type": "string" },
        "placement":   { "$ref": "#/$defs/placement" },
        "local_shape": { "$ref": "#/$defs/local_shape" },
        "polygon":     { "type": "array", "minItems": 3, "items": { "$ref": "#/$defs/point" } }
      }
    },

    "foundation_size": {
      "type": "object",
      "required": ["x", "y", "z"],
      "additionalProperties": false,
      "properties": {
        "x": { "type": "number", "exclusiveMinimum": 0 },
        "y": { "type": "number", "exclusiveMinimum": 0 },
        "z": { "type": "number", "exclusiveMinimum": 0 }
      }
    },

    "foundation_soil_cover": {
      "type": "object",
      "required": ["gamma_kNm3"],
      "additionalProperties": false,
      "properties": {
        "gamma_kNm3": { "type": "number", "exclusiveMinimum": 0 },
        "include_in_uplift": { "type": "boolean", "default": true }
      }
    },

    "foundation_soil_bearing": {
      "type": "object",
      "required": ["q_design_kPa"],
      "additionalProperties": false,
      "properties": {
        "q_design_kPa": { "type": "number", "exclusiveMinimum": 0 }
      }
    },

    "foundation_anchorage": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["reinforcing_dowels", "anchor_bolts", "unknown"] },
        "description": { "type": "string" }
      }
    },

    "foundation": {
      "type": "object",
      "required": ["id", "type", "supports", "size_mm", "ground_ref"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "type": { "const": "pad_footing" },
        "supports": { "type": "string" },
        "center": { "$ref": "#/$defs/point" },
        "size_mm": { "$ref": "#/$defs/foundation_size" },
        "material": { "type": "string" },
        "gamma_kNm3": { "type": "number", "exclusiveMinimum": 0 },
        "top_z": { "type": "number" },
        "ground_ref": { "type": "string" },
        "frost_insulated": { "type": "boolean", "default": false },
        "soil_cover": { "$ref": "#/$defs/foundation_soil_cover" },
        "soil_bearing": { "$ref": "#/$defs/foundation_soil_bearing" },
        "anchorage": { "$ref": "#/$defs/foundation_anchorage" }
      }
    },

    "column": {
      "type": "object",
      "required": ["id", "profile", "base", "top"],
      "additionalProperties": false,
      "properties": {
        "id":                   { "type": "string" },
        "profile":              { "type": "string" },
        "ref":                  { "type": "string" },
        "base":                 { "$ref": "#/$defs/point" },
        "top":                  { "$ref": "#/$defs/point" },
        "section_rotation_deg": { "type": "number", "default": 0 },
        "existing":             { "type": "boolean", "default": false }
      }
    },

    "beam": {
      "type": "object",
      "required": ["id", "profile", "axis_start", "axis_end"],
      "additionalProperties": false,
      "properties": {
        "id":                   { "type": "string" },
        "profile":              { "type": "string" },
        "ref":                  { "type": "string" },
        "axis_start":           { "$ref": "#/$defs/point" },
        "axis_end":             { "$ref": "#/$defs/point" },
        "mass_kg":              { "type": "number" },
        "section_rotation_deg": { "type": "number", "default": 0 },
        "existing":             { "type": "boolean", "default": false },
        "pattern": {
          "type": "object",
          "required": ["count", "offset"],
          "additionalProperties": false,
          "properties": {
            "count":       { "type": "integer", "minimum": 2 },
            "offset":      { "$ref": "#/$defs/point" },
            "id_template": { "type": "string" }
          }
        }
      }
    },

    "connection": {
      "type": "object",
      "required": ["id", "type", "members"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["wall_bolted", "supported_on", "supported_by_pattern", "notched_over", "pinned", "rafter_hanger", "column_base", "lateral_brace", "continuous", "transfer_link"]
        },
        "members":    { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "at":         { "$ref": "#/$defs/point" },
        "spacing_mm": { "type": "number" },
        "analysis":   { "$ref": "#/$defs/connection_analysis" },
        "transfer":   { "$ref": "#/$defs/transfer_link" },
        "detail":     { "$ref": "#/$defs/connection_detail" },
        "notch":      { "$ref": "#/$defs/notch" },
        "cuts": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/notch" }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "notched_over" } }
          },
          "then": {
            "required": ["at"],
            "anyOf": [
              { "required": ["notch"] },
              { "required": ["cuts"] }
            ]
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "transfer_link" } }
          },
          "then": {
            "required": ["at", "transfer"],
            "properties": {
              "members": {
                "minItems": 2,
                "maxItems": 2
              }
            }
          }
        }
      ]
    },

    "support_line_reference": {
      "type": "string",
      "enum": ["support_inner_edge", "support_outer_edge", "support_centerline"]
    },

    "support_model": {
      "type": "string",
      "enum": ["pinned", "semi_rigid", "rigid"]
    },

    "reaction_distribution": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["point", "uniform_over_supported_member_width", "uniform_over_width"]
        },
        "width_ref": {
          "type": "string",
          "enum": ["supported_member_profile_b"]
        },
        "width_mm": { "type": "number", "exclusiveMinimum": 0 },
        "label": { "type": "string" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "uniform_over_supported_member_width" } }
          },
          "then": {
            "required": ["width_ref"]
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "uniform_over_width" } }
          },
          "then": {
            "required": ["width_mm"]
          }
        }
      ]
    },

    "rotation_spring": {
      "type": "object",
      "required": ["model"],
      "additionalProperties": false,
      "properties": {
        "model":               { "type": "string", "enum": ["explicit", "ec5_fasteners"] },
        "k_theta_Nmm_per_rad": { "type": "number", "exclusiveMinimum": 0 },
        "fastener_d_mm":       { "type": "number", "exclusiveMinimum": 0 },
        "fastener_count":      { "type": "integer", "minimum": 1 },
        "effective_height_mm": { "type": "number", "exclusiveMinimum": 0 },
        "rho_kg_m3":           { "type": "number", "exclusiveMinimum": 0 }
      },
      "allOf": [
        {
          "if": {
            "properties": { "model": { "const": "explicit" } }
          },
          "then": {
            "required": ["k_theta_Nmm_per_rad"]
          }
        },
        {
          "if": {
            "properties": { "model": { "const": "ec5_fasteners" } }
          },
          "then": {
            "required": ["fastener_d_mm", "fastener_count", "effective_height_mm", "rho_kg_m3"]
          }
        }
      ]
    },

    "connection_analysis": {
      "type": "object",
      "required": ["support_model"],
      "additionalProperties": false,
      "properties": {
        "support_model":   { "$ref": "#/$defs/support_model" },
        "support_line_ref": { "$ref": "#/$defs/support_line_reference" },
        "reaction_distribution": { "$ref": "#/$defs/reaction_distribution" },
        "rotation_spring": { "$ref": "#/$defs/rotation_spring" },
        "label":           { "type": "string" },
        "fastener_label":  { "type": "string" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "support_model": { "const": "semi_rigid" } }
          },
          "then": {
            "required": ["rotation_spring"]
          }
        }
      ]
    },

    "bolt_grade": {
      "type": "string",
      "enum": ["4.6", "5.8", "8.8", "10.9"]
    },

    "transfer_link_fastener_member_ref": {
      "type": "string",
      "enum": ["member_a", "member_b"]
    },

    "transfer_link_fastener": {
      "type": "object",
      "required": [
        "id",
        "member_ref",
        "offset_along_strip_mm",
        "offset_height_mm"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "member_ref": { "$ref": "#/$defs/transfer_link_fastener_member_ref" },
        "offset_along_strip_mm": { "type": "number" },
        "offset_height_mm": { "type": "number" },
        "diameter_mm": { "type": "number", "exclusiveMinimum": 0 },
        "label": { "type": "string" }
      }
    },

    "transfer_link": {
      "type": "object",
      "required": [
        "model",
        "strip_width_mm",
        "plate_height_mm",
        "outer_plate_thickness_mm",
        "inner_plate_thickness_mm",
        "fastener_d_mm",
        "fastener_grade",
        "fastener_count_per_member"
      ],
      "additionalProperties": false,
      "properties": {
        "model":                    { "const": "strip_plate_bolts" },
        "description":              { "type": "string" },
        "strip_width_mm":           { "type": "number", "exclusiveMinimum": 0 },
        "plate_height_mm":          { "type": "number", "exclusiveMinimum": 0 },
        "outer_plate_thickness_mm": { "type": "number", "exclusiveMinimum": 0 },
        "inner_plate_thickness_mm": { "type": "number", "minimum": 0 },
        "fastener_d_mm":            { "type": "number", "exclusiveMinimum": 0 },
        "fastener_grade":           { "$ref": "#/$defs/bolt_grade" },
        "fastener_count_per_member": { "type": "integer", "minimum": 1 },
        "fasteners": {
          "type": "array",
          "items": { "$ref": "#/$defs/transfer_link_fastener" }
        }
      }
    },

    "connection_detail_host_member": {
      "type": "string",
      "enum": ["supported_member", "support_member"]
    },

    "detail_plate": {
      "type": "object",
      "required": [
        "id",
        "offset_across_center_mm"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "offset_across_center_mm": { "type": "number" },
        "label": { "type": "string" }
      }
    },

    "detail_point_kind": {
      "type": "string",
      "enum": ["hole_center", "connection_point"]
    },

    "detail_point": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "plate_id",
        "distance_from_visible_end_mm"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "kind": { "$ref": "#/$defs/detail_point_kind" },
        "plate_id": { "type": "string" },
        "label": { "type": "string" },
        "diameter_mm": { "type": "number", "exclusiveMinimum": 0 },
        "distance_from_visible_end_mm": { "type": "number", "minimum": 0 },
        "offset_across_plate_mm": { "type": "number", "default": 0 },
        "offset_vertical_mm": { "type": "number", "default": 0 }
      },
      "allOf": [
        {
          "if": {
            "properties": { "kind": { "const": "hole_center" } }
          },
          "then": {
            "required": ["diameter_mm"]
          }
        }
      ]
    },

    "plate_bracket_detail": {
      "type": "object",
      "required": [
        "kind",
        "host_member",
        "plate_width_mm",
        "plate_thickness_mm",
        "visible_length_mm",
        "embedded_length_mm",
        "plates"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "plate_bracket" },
        "description": { "type": "string" },
        "host_member": { "$ref": "#/$defs/connection_detail_host_member" },
        "plate_width_mm": { "type": "number", "exclusiveMinimum": 0 },
        "plate_thickness_mm": { "type": "number", "exclusiveMinimum": 0 },
        "visible_length_mm": { "type": "number", "exclusiveMinimum": 0 },
        "embedded_length_mm": { "type": "number", "exclusiveMinimum": 0 },
        "plates": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/detail_plate" }
        },
        "points": {
          "type": "array",
          "items": { "$ref": "#/$defs/detail_point" }
        }
      }
    },

    "connection_detail": {
      "oneOf": [
        { "$ref": "#/$defs/plate_bracket_detail" }
      ]
    },

    "cut_reference": {
      "type": "string",
      "enum": ["axis_start", "axis_end", "support_inner_edge", "support_outer_edge", "support_centerline"]
    },

    "load_transfer_reference": {
      "type": "string",
      "enum": ["axis_start", "axis_end", "support_inner_edge", "support_outer_edge", "support_centerline"]
    },

    "rect_notch": {
      "type": "object",
      "required": ["kind", "side", "reference", "depth_mm", "length_mm"],
      "additionalProperties": false,
      "properties": {
        "kind":                   { "const": "rect_notch" },
        "side":                   { "type": "string", "enum": ["bottom", "top"] },
        "reference":              { "$ref": "#/$defs/cut_reference" },
        "offset_mm":              { "type": "number", "default": 0 },
        "x_from_support_edge_mm": { "type": "number", "default": 0 },
        "depth_mm":               { "type": "number", "exclusiveMinimum": 0 },
        "length_mm":              { "type": "number", "exclusiveMinimum": 0 }
      }
    },

    "birdsmouth_notch": {
      "type": "object",
      "required": ["kind", "reference", "heel_depth_mm", "seat_length_mm"],
      "additionalProperties": false,
      "properties": {
        "kind":                   { "const": "birdsmouth_notch" },
        "reference":              { "$ref": "#/$defs/cut_reference" },
        "offset_mm":              { "type": "number", "default": 0 },
        "x_from_support_edge_mm": { "type": "number", "default": 0 },
        "heel_depth_mm":          { "type": "number", "exclusiveMinimum": 0 },
        "seat_length_mm":         { "type": "number", "exclusiveMinimum": 0 }
      }
    },

    "end_bevel_cut": {
      "type": "object",
      "required": ["kind", "reference", "cut_from", "length_mm"],
      "additionalProperties": false,
      "properties": {
        "kind":                   { "const": "end_bevel_cut" },
        "reference":              { "$ref": "#/$defs/cut_reference" },
        "offset_mm":              { "type": "number", "default": 0 },
        "x_from_support_edge_mm": { "type": "number", "default": 0 },
        "cut_from":               { "type": "string", "enum": ["bottom", "top"] },
        "length_mm":              { "type": "number", "exclusiveMinimum": 0 }
      }
    },

    "bevel_notch": {
      "type": "object",
      "required": ["kind", "side", "reference", "depth_mm", "length_mm"],
      "additionalProperties": false,
      "properties": {
        "kind":                   { "const": "bevel_notch" },
        "side":                   { "type": "string", "enum": ["bottom", "top"] },
        "reference":              { "$ref": "#/$defs/cut_reference" },
        "offset_mm":              { "type": "number", "default": 0 },
        "x_from_support_edge_mm": { "type": "number", "default": 0 },
        "depth_mm":               { "type": "number", "exclusiveMinimum": 0 },
        "length_mm":              { "type": "number", "exclusiveMinimum": 0 }
      }
    },

    "notch": {
      "oneOf": [
        { "$ref": "#/$defs/rect_notch" },
        { "$ref": "#/$defs/birdsmouth_notch" },
        { "$ref": "#/$defs/end_bevel_cut" },
        { "$ref": "#/$defs/bevel_notch" }
      ]
    },

    "surface": {
      "type": "object",
      "required": ["id", "type", "placement", "local_shape"],
      "additionalProperties": false,
      "properties": {
        "id":           { "type": "string" },
        "type":         { "type": "string", "enum": ["roof_covering", "solar_panel_array", "side_glazing", "triangle_glazing", "gable_glazing", "opening", "boarding", "purlin_layer"] },
        "ref":          { "type": "string" },
        "placement":    { "$ref": "#/$defs/placement" },
        "local_shape":  { "$ref": "#/$defs/local_shape" },
        "polygon":      { "type": "array", "minItems": 3, "items": { "$ref": "#/$defs/point" } },
        "material":     { "type": "string" },
        "thickness_mm": { "type": "number" },
        "mass_kg":      { "type": "number" },
        "count": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "nx":            { "type": "integer", "minimum": 1 },
            "ny":            { "type": "integer", "minimum": 1 },
            "unit_size_mm":  { "$ref": "#/$defs/point" },
            "unit_mass_kg":  { "type": "number" }
          }
        },
        "load_transfer": { "$ref": "#/$defs/surface_load_transfer" },
        "supported_by": { "type": "array", "items": { "type": "string" } },
        "openable":     { "type": "boolean" }
      }
    },

    "surface_load_transfer_rule": {
      "type": "object",
      "required": ["member_refs", "model"],
      "additionalProperties": false,
      "properties": {
        "member_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string" }
        },
        "model":        { "type": "string", "enum": ["point", "uniform", "partial_uniform"] },
        "reference":    { "$ref": "#/$defs/load_transfer_reference" },
        "offset_mm":    { "type": "number", "default": 0 },
        "length_mm":    { "type": "number", "exclusiveMinimum": 0 }
      },
      "allOf": [
        {
          "if": {
            "properties": { "model": { "const": "point" } }
          },
          "then": {
            "required": ["reference"]
          }
        },
        {
          "if": {
            "properties": { "model": { "const": "partial_uniform" } }
          },
          "then": {
            "required": ["reference", "length_mm"]
          }
        }
      ]
    },

    "surface_load_transfer": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "to_members": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/surface_load_transfer_rule" }
        }
      }
    },

    "axis": {
      "type": "object",
      "required": ["dir"],
      "additionalProperties": false,
      "properties": {
        "dir":             { "type": "string", "enum": ["+x", "-x", "+y", "-y", "+z", "-z"] },
        "length_mm":       { "type": "number" },
        "horizontal_mm":   { "type": "number" },
        "rise_mm":         { "type": "number" },
        "slope_deg":       { "type": "number" },
        "slope_sense":     { "type": "string", "enum": ["+x", "-x", "+y", "-y", "+z", "-z"] },
        "slope_length_mm": { "type": "number" }
      }
    },

    "placement": {
      "type": "object",
      "required": ["anchor", "u", "v"],
      "additionalProperties": false,
      "properties": {
        "anchor": { "$ref": "#/$defs/point" },
        "u":      { "$ref": "#/$defs/axis" },
        "v":      { "$ref": "#/$defs/axis" }
      }
    },

    "local_shape": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type":        { "type": "string", "enum": ["rectangle", "polygon"] },
        "vertices_uv": {
          "type": "array",
          "minItems": 3,
          "items": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "type": "number" } }
        }
      }
    }
  }
}
